#!/usr/bin/env bash
# excli [--tui] <file.excalidraw>
#   Open a drawing in the real Excalidraw, autosaving edits back to the file.
#     default  opens in your browser — crisp, native trackpad pan/zoom.
#     --tui    renders in this terminal via Carbonyl — blocky; for SSH/headless.
set -euo pipefail

usage() {
  cat <<'EOF'
excli — open a .excalidraw file in the real Excalidraw, autosaving to the file.

Usage:
  excli <file.excalidraw>          Open in your browser (crisp, native trackpad).
  excli --tui <file.excalidraw>    Render in this terminal via Carbonyl (blocky;
                                   for SSH/headless — needs: npm install).
  excli -h | --help                Show this help.

Notes:
  - A path that doesn't exist yet starts a blank canvas, created on first save.
  - Edits autosave ~500ms after you stop drawing.
  - In browser mode this terminal stays running as the autosave server; leave it
    open while editing and press Ctrl-C when done.
  - Theme, prefs, and libraries persist in ~/.config/excalidraw-tui/config.json.
EOF
}

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage
  exit 0
fi

tui=0
if [ "${1:-}" = "--tui" ]; then
  tui=1
  shift
fi

if [ $# -lt 1 ]; then
  usage >&2
  exit 1
fi

file="$1"
# New file -> create it empty so the path resolves. The server serves a blank
# canvas for an empty file; the first save writes real content.
[ -e "$file" ] || : >"$file"

here="$(cd "$(dirname "$0")" && pwd)"

# Start the server in the background; it prints its chosen port to this file.
# (tempfile + poll instead of coproc, so this works on macOS's bash 3.2.)
portfile="$(mktemp)"
python3 "$here/server.py" "$file" >"$portfile" &
server_pid=$!

cleanup() { kill "$server_pid" 2>/dev/null || true; rm -f "$portfile"; }
trap cleanup EXIT INT TERM

# Wait (up to ~5s) for the server to report its port.
port=""
for _ in $(seq 1 50); do
  port="$(cat "$portfile")"
  [ -n "$port" ] && break
  sleep 0.1
done
if [ -z "$port" ]; then
  echo "server didn't start" >&2
  exit 1
fi

url="http://127.0.0.1:$port/"

if [ "$tui" -eq 1 ]; then
  # Terminal mode: Carbonyl runs in the foreground and blocks until you quit,
  # which keeps the server alive for the session.
  carbonyl="$here/node_modules/.bin/carbonyl"
  if [ ! -x "$carbonyl" ]; then
    echo "carbonyl not installed — run: npm install" >&2
    exit 1
  fi
  "$carbonyl" "$url"
else
  # Browser mode: open the URL, then keep this terminal alive as the autosave
  # server until you Ctrl-C.
  if command -v open >/dev/null 2>&1; then
    open "$url"
  elif command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$url"
  else
    echo "open this in your browser: $url"
  fi
  echo "Excalidraw is open in your browser — edits autosave to $file"
  echo "Press Ctrl-C here to stop."
  wait "$server_pid"
fi
